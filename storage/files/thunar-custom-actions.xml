<?xml version="1.0" encoding="UTF-8"?>
<actions>
<action>
	<icon>utilities-terminal</icon>
	<name>Open terminal</name>
	<submenu></submenu>
	<unique-id>1781192030725142-1</unique-id>
	<command>xdg-terminal-exec --dir=%f</command>
	<description>Open the default terminal emulator in the current directory</description>
	<range></range>
	<patterns>*</patterns>
	<startup-notify/>
	<directories/>
</action>
<action>
	<icon>folder-red-important</icon>
	<name>Open as root</name>
	<submenu></submenu>
	<unique-id>1781286246434971-1</unique-id>
	<command>run0 env XDG_RUNTIME_DIR=&quot;$XDG_RUNTIME_DIR&quot; WAYLAND_DISPLAY=&quot;$WAYLAND_DISPLAY&quot; thunar %f</command>
	<description>Open the current directory as the root user</description>
	<range></range>
	<patterns>*</patterns>
	<directories/>
</action>
</actions>
